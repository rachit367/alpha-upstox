# ─────────────────────────────────────────────────────────────
# TELEGRAM CONFIGURATION
# ─────────────────────────────────────────────────────────────
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE_NUMBER=your_phone_number_with_country_code
TELEGRAM_SESSION_STRING=
TELEGRAM_GROUP_ID=
TELEGRAM_FETCH_INTERVAL=60          # seconds between fetches

# ─────────────────────────────────────────────────────────────
# LLM CONFIGURATION
# Values: openrouter | openai
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# UPSTOX API CONFIGURATION
# ─────────────────────────────────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_ACCESS_TOKEN=your_upstox_access_token
UPSTOX_BASE_URL=https://api.upstox.com/v2

# ─────────────────────────────────────────────────────────────
# TRADE CONFIGURATION
# ─────────────────────────────────────────────────────────────
TRADE_LOTS=1                        # Number of lots per trade (Calculated automatically for NIFTY, BANKNIFTY, etc.)
TRADE_QUANTITY_PER_LOT=50           # Default fallback qty per lot (e.g. for individual equity stocks)

# ─────────────────────────────────────────────────────────────
# RISK MANAGEMENT
# ─────────────────────────────────────────────────────────────
MAX_TRADES_PER_DAY=5
MAX_DAILY_LOSS=10000                # in INR

ENABLE_STOP_LOSS=true
ENABLE_TRAILING_SL=true
ENABLE_TARGETS=true

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/alphabot
